{
  "openapi": "3.1.0",
  "info": {
    "title": "Raindrop AI Provider API",
    "version": "1.0.0",
    "description": "Authenticated user-scoped AI Provider metadata and credential mutation. Credentials are write-only and are never returned."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    {
      "name": "AI Providers"
    }
  ],
  "paths": {
    "/api/v1/ai/providers": {
      "get": {
        "tags": [
          "AI Providers"
        ],
        "operationId": "listAiProviders",
        "summary": "List instance and current-user AI Providers visible to the current user",
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/ProviderList"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          },
          "500": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "post": {
        "tags": [
          "AI Providers"
        ],
        "operationId": "createAiProvider",
        "summary": "Create a current-user AI Provider",
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CsrfToken"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProviderRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/CreatedProvider"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          },
          "403": {
            "$ref": "#/components/responses/Error"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          },
          "422": {
            "$ref": "#/components/responses/Error"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/Error"
          },
          "503": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/v1/ai/providers/{providerId}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/ProviderId"
        }
      ],
      "get": {
        "tags": [
          "AI Providers"
        ],
        "operationId": "getAiProvider",
        "summary": "Get one visible AI Provider",
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Provider"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          },
          "422": {
            "$ref": "#/components/responses/Error"
          },
          "500": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "patch": {
        "tags": [
          "AI Providers"
        ],
        "operationId": "patchAiProvider",
        "summary": "Partially update a current-user AI Provider",
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CsrfToken"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProviderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Provider"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          },
          "403": {
            "$ref": "#/components/responses/Error"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          },
          "422": {
            "$ref": "#/components/responses/Error"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/Error"
          },
          "503": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "sessionCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "raindrop_session"
      }
    },
    "parameters": {
      "ProviderId": {
        "name": "providerId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "CsrfToken": {
        "name": "x-csrf-token",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "headers": {
      "CacheControl": {
        "description": "AI Provider responses are never stored.",
        "schema": {
          "type": "string",
          "enum": [
            "no-store"
          ]
        }
      },
      "Pragma": {
        "description": "Compatibility cache directive.",
        "schema": {
          "type": "string",
          "enum": [
            "no-cache"
          ]
        }
      },
      "Location": {
        "description": "Canonical URL of the created AI Provider.",
        "schema": {
          "type": "string",
          "pattern": "^/api/v1/ai/providers/[0-9a-f-]{36}$"
        }
      },
      "RetryAfter": {
        "description": "Seconds until the Provider mutation may be retried.",
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "schemas": {
      "ProviderCapabilities": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "supportsUsage",
          "supportsIdempotency"
        ],
        "properties": {
          "supportsUsage": {
            "type": "boolean"
          },
          "supportsIdempotency": {
            "type": "boolean"
          }
        }
      },
      "ProviderPolicy": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "maxConcurrency",
          "requestsPerMinute",
          "maxInputTokensPerRequest",
          "maxOutputTokensPerRequest",
          "inputCostMicrosPerMillionTokens",
          "outputCostMicrosPerMillionTokens",
          "maxCostMicrosPerRequest"
        ],
        "properties": {
          "maxConcurrency": {
            "type": "integer",
            "minimum": 1,
            "maximum": 64
          },
          "requestsPerMinute": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1,
            "maximum": 1000000
          },
          "maxInputTokensPerRequest": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1048576
          },
          "maxOutputTokensPerRequest": {
            "type": "integer",
            "minimum": 1,
            "maximum": 16384
          },
          "inputCostMicrosPerMillionTokens": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0,
            "maximum": 1000000000000
          },
          "outputCostMicrosPerMillionTokens": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0,
            "maximum": 1000000000000
          },
          "maxCostMicrosPerRequest": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0,
            "maximum": 1000000000000
          }
        }
      },
      "ProviderKind": {
        "type": "string",
        "enum": [
          "ANTHROPIC_MESSAGES",
          "OPENAI_RESPONSES",
          "OPENAI_CHAT_COMPLETIONS",
          "GOOGLE_GEMINI"
        ]
      },
      "Provider": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "providerId",
          "scope",
          "canEdit",
          "displayName",
          "kind",
          "endpoint",
          "model",
          "capabilities",
          "policy",
          "isEnabled",
          "revision",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "providerId": {
            "type": "string",
            "format": "uuid"
          },
          "scope": {
            "type": "string",
            "enum": [
              "INSTANCE",
              "USER"
            ]
          },
          "canEdit": {
            "type": "boolean"
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "kind": {
            "$ref": "#/components/schemas/ProviderKind"
          },
          "endpoint": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://",
            "maxLength": 2048
          },
          "model": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "capabilities": {
            "$ref": "#/components/schemas/ProviderCapabilities"
          },
          "policy": {
            "$ref": "#/components/schemas/ProviderPolicy"
          },
          "isEnabled": {
            "type": "boolean"
          },
          "revision": {
            "type": "integer",
            "minimum": 0
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ProviderList": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "keyringStatus",
          "items"
        ],
        "properties": {
          "keyringStatus": {
            "type": "string",
            "enum": [
              "AVAILABLE",
              "UNAVAILABLE"
            ]
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Provider"
            }
          }
        }
      },
      "CreateProviderRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "displayName",
          "kind",
          "endpoint",
          "model",
          "credential",
          "capabilities",
          "policy",
          "isEnabled"
        ],
        "properties": {
          "displayName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "kind": {
            "$ref": "#/components/schemas/ProviderKind"
          },
          "endpoint": {
            "type": [
              "string",
              "null"
            ],
            "format": "uri",
            "pattern": "^https://",
            "maxLength": 2048,
            "description": "Null selects the canonical endpoint for the Provider kind."
          },
          "model": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "credential": {
            "type": "string",
            "minLength": 1,
            "maxLength": 8192,
            "writeOnly": true
          },
          "capabilities": {
            "$ref": "#/components/schemas/ProviderCapabilities"
          },
          "policy": {
            "$ref": "#/components/schemas/ProviderPolicy"
          },
          "isEnabled": {
            "type": "boolean"
          }
        }
      },
      "UpdateProviderRequest": {
        "type": "object",
        "additionalProperties": false,
        "minProperties": 2,
        "required": [
          "expectedRevision"
        ],
        "properties": {
          "expectedRevision": {
            "type": "integer",
            "minimum": 0
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "endpoint": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://",
            "maxLength": 2048
          },
          "model": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "credential": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1,
            "maxLength": 8192,
            "writeOnly": true,
            "description": "Omitted or null preserves the current credential. A non-empty string rotates it."
          },
          "capabilities": {
            "$ref": "#/components/schemas/ProviderCapabilities"
          },
          "policy": {
            "$ref": "#/components/schemas/ProviderPolicy"
          },
          "isEnabled": {
            "type": "boolean"
          }
        }
      },
      "ApiError": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message",
          "requestId"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "fields": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "requestId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "ApiErrorEnvelope": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ApiError"
          }
        }
      }
    },
    "responses": {
      "ProviderList": {
        "description": "Visible AI Providers and keyring availability.",
        "headers": {
          "Cache-Control": {
            "$ref": "#/components/headers/CacheControl"
          },
          "Pragma": {
            "$ref": "#/components/headers/Pragma"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ProviderList"
            }
          }
        }
      },
      "Provider": {
        "description": "One visible AI Provider without credential material.",
        "headers": {
          "Cache-Control": {
            "$ref": "#/components/headers/CacheControl"
          },
          "Pragma": {
            "$ref": "#/components/headers/Pragma"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Provider"
            }
          }
        }
      },
      "CreatedProvider": {
        "description": "A newly created current-user AI Provider.",
        "headers": {
          "Cache-Control": {
            "$ref": "#/components/headers/CacheControl"
          },
          "Pragma": {
            "$ref": "#/components/headers/Pragma"
          },
          "Location": {
            "$ref": "#/components/headers/Location"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Provider"
            }
          }
        }
      },
      "Error": {
        "description": "Stable public error envelope.",
        "headers": {
          "Cache-Control": {
            "$ref": "#/components/headers/CacheControl"
          },
          "Pragma": {
            "$ref": "#/components/headers/Pragma"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiErrorEnvelope"
            }
          }
        }
      },
      "RateLimited": {
        "description": "The per-user AI Provider mutation budget is exhausted.",
        "headers": {
          "Cache-Control": {
            "$ref": "#/components/headers/CacheControl"
          },
          "Pragma": {
            "$ref": "#/components/headers/Pragma"
          },
          "Retry-After": {
            "$ref": "#/components/headers/RetryAfter"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiErrorEnvelope"
            }
          }
        }
      }
    }
  }
}
