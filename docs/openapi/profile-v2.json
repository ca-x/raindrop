{
  "openapi": "3.1.0",
  "info": {
    "title": "Raindrop Current User Profile API",
    "version": "2.0.0",
    "description": "Authenticated current-user profile metadata. Username is a read-only login identifier; display name and email are optional mutable fields."
  },
  "servers": [{ "url": "/" }],
  "tags": [{ "name": "Profile" }],
  "paths": {
    "/api/v2/profile": {
      "get": {
        "tags": ["Profile"],
        "operationId": "getCurrentUserProfile",
        "summary": "Get the current user's profile",
        "security": [{ "sessionCookie": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/Profile" },
          "401": { "$ref": "#/components/responses/Error" },
          "500": { "$ref": "#/components/responses/Error" }
        }
      },
      "patch": {
        "tags": ["Profile"],
        "operationId": "patchCurrentUserProfile",
        "summary": "Partially update the current user's display name or email",
        "security": [{ "sessionCookie": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CsrfToken" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PatchUserProfileRequest" }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/Profile" },
          "401": { "$ref": "#/components/responses/Error" },
          "403": { "$ref": "#/components/responses/Error" },
          "409": { "$ref": "#/components/responses/Error" },
          "422": { "$ref": "#/components/responses/Error" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/Error" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "sessionCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "raindrop_session"
      }
    },
    "parameters": {
      "CsrfToken": {
        "name": "x-csrf-token",
        "in": "header",
        "required": true,
        "schema": { "type": "string" }
      }
    },
    "headers": {
      "CacheControl": {
        "description": "Profile responses are never stored.",
        "schema": { "type": "string", "enum": ["no-store"] }
      },
      "Pragma": {
        "description": "Compatibility cache directive.",
        "schema": { "type": "string", "enum": ["no-cache"] }
      },
      "RetryAfter": {
        "description": "Seconds until the profile mutation may be retried.",
        "schema": { "type": "integer", "minimum": 1 }
      }
    },
    "schemas": {
      "UserProfile": {
        "type": "object",
        "additionalProperties": false,
        "required": ["userId", "username", "displayName", "email"],
        "properties": {
          "userId": { "type": "string", "format": "uuid" },
          "username": { "type": "string", "minLength": 3, "maxLength": 64 },
          "displayName": {
            "description": "Optional user-facing nickname. Null falls back to username.",
            "type": ["string", "null"],
            "minLength": 1,
            "maxLength": 80
          },
          "email": {
            "description": "Optional normalized login email.",
            "type": ["string", "null"],
            "minLength": 3,
            "maxLength": 320
          }
        }
      },
      "PatchUserProfileRequest": {
        "type": "object",
        "additionalProperties": false,
        "minProperties": 1,
        "properties": {
          "displayName": { "type": ["string", "null"], "maxLength": 80 },
          "email": { "type": ["string", "null"], "maxLength": 320 }
        }
      },
      "ApiError": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "requestId"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "fields": { "type": "object", "additionalProperties": { "type": "string" } },
          "requestId": { "type": "string", "format": "uuid" }
        }
      },
      "ApiErrorEnvelope": {
        "type": "object",
        "additionalProperties": false,
        "required": ["error"],
        "properties": { "error": { "$ref": "#/components/schemas/ApiError" } }
      }
    },
    "responses": {
      "Profile": {
        "description": "Current user's complete profile.",
        "headers": {
          "Cache-Control": { "$ref": "#/components/headers/CacheControl" },
          "Pragma": { "$ref": "#/components/headers/Pragma" }
        },
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/UserProfile" } }
        }
      },
      "Error": {
        "description": "Stable public error envelope.",
        "headers": {
          "Cache-Control": { "$ref": "#/components/headers/CacheControl" },
          "Pragma": { "$ref": "#/components/headers/Pragma" }
        },
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/ApiErrorEnvelope" } }
        }
      },
      "RateLimited": {
        "description": "The per-user settings mutation budget is exhausted.",
        "headers": {
          "Cache-Control": { "$ref": "#/components/headers/CacheControl" },
          "Pragma": { "$ref": "#/components/headers/Pragma" },
          "Retry-After": { "$ref": "#/components/headers/RetryAfter" }
        },
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/ApiErrorEnvelope" } }
        }
      }
    }
  }
}
