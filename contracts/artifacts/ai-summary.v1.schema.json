{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "raindrop://schemas/artifacts/ai-summary/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sourceLanguage",
    "summary",
    "bullets",
    "conclusion"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "sourceLanguage": {
      "type": "string",
      "minLength": 2,
      "maxLength": 35,
      "pattern": "^[A-Za-z]{2,8}(-[A-Za-z0-9]{1,8})*$"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 65536
    },
    "bullets": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 8192
      }
    },
    "conclusion": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 16384
    }
  }
}
