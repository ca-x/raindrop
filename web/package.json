{
  "name": "raindrop-web",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@12.0.1",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "generate:reader-types": "node scripts/generate-reader-types.mjs",
    "check:reader-types": "node scripts/generate-reader-types.mjs --check",
    "check:release-contracts": "node scripts/verify-release-contracts.mjs",
    "typecheck": "tsc -b --pretty false",
    "test:ci": "vitest run",
    "test:embedded": "npm run build && npm run test:embedded:rust",
    "test:embedded:rust": "cargo test --release --lib --manifest-path ../Cargo.toml && cargo test --release --test embedded_web --manifest-path ../Cargo.toml && cargo test --release --test embedded_official_ai_bundle --manifest-path ../Cargo.toml",
    "test:e2e": "npm run test:e2e:prepare && playwright test",
    "test:e2e:prepare": "npm run test:embedded && cargo build --release --locked --manifest-path ../Cargo.toml",
    "test:e2e:install-browser": "playwright install chromium",
    "lint": "tsc -b --pretty false",
    "astryx:check": "node node_modules/@astryxdesign/core/docs.mjs --list --brief",
    "i18n:extract": "lingui extract"
  },
  "dependencies": {
    "@astryxdesign/core": "0.1.6",
    "@astryxdesign/theme-neutral": "0.1.6",
    "@lingui/core": "6.5.0",
    "@lingui/react": "6.5.0",
    "@stylexjs/stylex": "0.19.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1"
  },
  "devDependencies": {
    "@astryxdesign/cli": "0.1.6",
    "@lingui/cli": "6.5.0",
    "@lingui/conf": "6.5.0",
    "@lingui/format-po": "6.5.0",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
