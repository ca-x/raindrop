# Raindrop 不会自动加载 .env。请由 shell、容器或服务管理器注入这些变量。
# 复制为 .env 后必须替换 CHANGE_ME_*，不要提交 .env。

RAINDROP_DATA_DIR=./data
RAINDROP_BIND=127.0.0.1:8080
RAINDROP_PUBLIC_URL=http://127.0.0.1:8080
RAINDROP_DATABASE_URL=sqlite://data/raindrop.db?mode=rwc

# orphan Feed 的物理清理宽限期，默认 30 天；设为 0 可禁用，最大 3650。
# RAINDROP_FEED_ORPHAN_RETENTION_DAYS=30

# 当前阶段可选。启用时至少 32 字节，并使用随机值。
# RAINDROP_SESSION_SECRET=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_BYTES

# AI provider credential 的独立 active-first keyring；当前 provider 管理 UI/API 尚未接通。
# key material 必须是 32 随机字节的无 padding URL-safe base64，不得复用 session secret。
# RAINDROP_PROVIDER_SECRET_KEYS=primary:CHANGE_ME_WITH_32_BYTE_BASE64URL_NO_PADDING

RAINDROP_BOOTSTRAP_ADMIN_USERNAME=admin
RAINDROP_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_WITH_AT_LEAST_12_RANDOM_BYTES
# RAINDROP_BOOTSTRAP_ADMIN_EMAIL=admin@example.invalid
